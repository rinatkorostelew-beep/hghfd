<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Animated background particles -->
    <com.bighead.app.ParticleView
        android:id="@+id/particleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Circle overlay — DIGTER mode -->
    <com.bighead.app.CircleOverlayView
        android:id="@+id/circleOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        android:alpha="0" />

    <!-- ===== DRAGGABLE GROUP (panel + slider move together) ===== -->
    <LinearLayout
        android:id="@+id/draggableGroup"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="invisible"
        android:alpha="0">

        <!-- Panel card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/panelCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/panel_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:strokeColor="@color/accent_purple"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Drag handle indicator -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/drag_handle" />

                <!-- Toggle row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/toggle_track"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/btnBigHead"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/toggle_selected"
                        android:gravity="center"
                        android:text="BIGHEAD"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                         />

                    <TextView
                        android:id="@+id/btnDigter"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/toggle_unselected"
                        android:gravity="center"
                        android:text="DIGTER"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                         />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- BIGHEAD Slider — appears below panel -->
        <LinearLayout
            android:id="@+id/bigheadSliderContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible"
            android:alpha="1"
            android:layout_marginTop="8dp"
            android:background="@drawable/slider_panel_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEAD SIZE"
                android:textColor="@color/accent_cyan"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                
                android:layout_marginBottom="6dp" />

            <SeekBar
                android:id="@+id/bigheadSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:progressTint="@color/accent_purple"
                android:thumbTint="@color/accent_purple" />

        </LinearLayout>

        <!-- DIGTER Slider — circle size -->
        <LinearLayout
            android:id="@+id/digterSliderContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:alpha="0"
            android:layout_marginTop="8dp"
            android:background="@drawable/slider_panel_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CIRCLE SIZE"
                android:textColor="@color/accent_cyan"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                
                android:layout_marginBottom="6dp" />

            <SeekBar
                android:id="@+id/digterSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="40"
                android:progressTint="@color/accent_cyan"
                android:thumbTint="@color/accent_cyan" />

        </LinearLayout>

    </LinearLayout>
    <!-- ===== END DRAGGABLE GROUP ===== -->

    <!-- Launch / Close button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLaunch"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="56dp"
        android:text="ЗАПУСТИТЬ"
        android:textSize="14sp"
        android:letterSpacing="0.12"
        
        app:backgroundTint="@color/accent_purple"
        app:cornerRadius="28dp"
        app:elevation="8dp"
        app:icon="@drawable/ic_launch"
        app:iconGravity="textStart"
        app:iconPadding="8dp" />

</FrameLayout>
